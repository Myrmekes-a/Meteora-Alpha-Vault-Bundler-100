RPC_URL=https://mainnet.helius-rpc.com/?api-key=
CLUSTER=mainnet-beta

# Existing DAMM v2 config account
CONFIG_ADDRESS=8CNy9goNQNLM4wtgRw528tUQGMKD3vSuFRZY2gLGLLvF

TOKEN_A_INPUT_AMOUNT_RAW=1000000000000000
# Empty = auto-compute from token amounts
INITIAL_PRICE=
TOKEN_B_INPUT_AMOUNT_RAW=100000000

DRY_RUN=false
IS_LOCK_LIQUIDITY=false

QUOTE_MINT_TYPE=WSOL
TOKEN_PROGRAM=TOKEN_2022
TOKEN_DECIMALS=6
TOKEN_INITIAL_SUPPLY_RAW=1000000000000000
CONNECT_ALPHA_VAULT_POOL=true
# POOL_QUICK_ACTIVATION=true  # Disabled: Meteora rejects short activation on-chain

# Optional fallback keys (kept for compatibility)
BASE_TOKEN_PROGRAM=TOKEN_2022
BASE_MINT_DECIMALS=6
BASE_INITIAL_SUPPLY_RAW=1000000000000000

# token metadata
TOKEN_NAME=XD
TOKEN_SYMBOL=XD TOKEN
TOKEN_DESCRIPTION=Meteora DAMM v2 XD token.
TOKEN_IMAGE_PATH=image/XD.jpg
TOKEN_SOCIAL_LINKS=[]

# Pinata API keys
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Alpha Vault FCFS settings (raw quote units)
# WSOL: lamports, USDC: 6 decimals
ALPHA_FCFS_MAX_DEPOSITING_CAP_RAW=10000000000
ALPHA_FCFS_INDIVIDUAL_CAP_RAW=70000000
ALPHA_FCFS_WHITELIST_MODE=permissionless
ALPHA_FCFS_ESCROW_FEE_RAW=0
# Claim lock: seconds after pool activation before users can claim. 1800 = 30 min
ALPHA_FCFS_CLAIM_LOCK_AFTER_ACTIVATION_SEC=1800

# Pool activation: seconds from now. 7200=2h (shortest that passes Meteora 6021)
POOL_ACTIVATION_POINT_TS=7200
# depositingPoint = chain_now + this. 900=15min. Deposit closes T+55min
ALPHA_FCFS_DEPOSIT_OPEN_BUFFER_SEC=900

# Launch state and distribution
DISTRIBUTION_WALLET_SOL_FEE_BUFFER_LAMPORTS=20000000
MAIN_WALLET_FEE_RESERVE_LAMPORTS=50000000

# Auto wallet generation
DISTRIBUTION_WALLET_COUNT=2
DISTRIBUTION_TOTAL_DEPOSIT_RAW=1000000000
DISTRIBUTION_RANDOMIZE_AMOUNTS=true

# Fill: seconds before pool activation when fill runs. Use 40 for retry window
FILL_BUFFER_SEC_BEFORE_ACTIVATION=40
# SKIP_FILL_WAIT=true exits early if fill window not open (instead of waiting)

# LaserStream (for listen:pool - pool event streaming)
LASERSTREAM_API_KEY=
LASERSTREAM_ENDPOINT=https://laserstream-mainnet-fra.helius-rpc.com
BIRDEYE_API_KEY=
# Pool is auto-resolved from Mongo launch state by listen:pool

TARGET_BUY_AMOUNT=1 # sol
SELL_PERCENTAGE=70 # %
BUY_PERCENTAGE=5 # %

MONGODB_URI=
MONGODB_DB_NAME=meteora_alpha_vault_bundler



WALLET_SECRET_KEY=
REPLICATOR_WALLET_COUNT=2
SLIPPAGE_BPS=100